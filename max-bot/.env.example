# ── MAX Bot ──
MAX_BOT_TOKEN=your_max_bot_token
ADMIN_IDS=449745697

# ── PostgreSQL ──
DATABASE_URL=postgresql://bot:bot@db:5432/transcription_bot_max

# ── Yandex SpeechKit ──
YANDEX_API_KEY=your_yandex_api_key
YANDEX_FOLDER_ID=your_folder_id

# ── OpenRouter (LLM) ──
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ── Тарификация (в рублях) ──
FREE_TRIAL_MAX_MINUTES=41
SUBSCRIPTION_PRICE_RUB=300
SUBSCRIPTION_MINUTES=600
PRICE_PER_MINUTE_RUB=4
THESES_PRICE_RUB=15
PROTOCOL_PRICE_RUB=15

# ── T-Bank Интернет-эквайринг ──
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=
# URL вашего сервера, куда T-Bank отправит уведомление об оплате
# Для теста через ngrok: https://xxxx.ngrok-free.app/tinkoff/notify
TINKOFF_NOTIFICATION_URL=
TINKOFF_SUCCESS_URL=
TINKOFF_FAIL_URL=
# Порт webhook-сервера (внутренний, должен быть проброшен наружу)
WEBHOOK_PORT=8080

# ── Прокси ──
PROXY_URL=

# ── Лимиты ──
TEMP_DIR=data/temp
MAX_FILE_SIZE_MB=50
LOG_LEVEL=INFO
